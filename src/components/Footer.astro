---
import * as footerData from '../data/footer.md';
import Icon from './Icon.astro';
import esTranslations from '../i18n/es.json';
import enTranslations from '../i18n/en.json';

const { brand, socialLinks, legalLinks } = footerData.frontmatter as {
  brand: string;
  socialLinks: { url: string; icon: string }[];
  legalLinks: { url: string; id: string }[];
};
const { lang = 'es' } = Astro.props;
const t = lang === 'en' ? enTranslations : esTranslations;
---

<footer
  class="w-full border-t border-black/5 dark:border-white/5 bg-surface-container-lowest"
>
  <div class="max-w-7xl mx-auto px-8 py-16">
    <div class="flex flex-col md:flex-row justify-between items-center gap-10">
      <div class="text-center md:text-left">
        <div
          class="text-2xl font-bold font-manrope tracking-tighter mb-2"
        >
          {brand}
        </div>
        <p class="text-on-surface-variant text-sm font-medium tracking-wide">
          {t.footer.copyright}
        </p>
      </div>
      <div class="flex items-center gap-6">
        {
          socialLinks.map((link) => (
            <a
              class="w-12 h-12 flex items-center justify-center rounded-2xl bg-black/5 dark:bg-white/5 border border-black/10 dark:border-white/10 text-on-surface-variant hover:text-primary hover:border-primary/40 transition-all duration-300 group social-glow"
              href={link.url}
            >
              <Icon name={link.icon} class="w-6 h-6 group-hover:scale-110 transition-transform" />
            </a>
          ))
        }
      </div>
    </div>
    <div
      class="mt-12 pt-8 border-t border-black/5 dark:border-white/5 flex flex-wrap justify-center gap-x-8 gap-y-4 text-[10px] font-bold uppercase tracking-[0.2em] text-outline"
    >
      {
        legalLinks.map((link) => (
          <a
            class="hover:text-primary transition-colors"
            href={`/${lang}${link.url}`}
          >
            {t.footer.links[link.id as keyof typeof t.footer.links]}
          </a>
        ))
      }
    </div>
  </div>
</footer>
