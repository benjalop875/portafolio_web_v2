---
import Section from "./Section.astro";
import TechItem from "./TechItem.astro";
import ProjectCard from "./ProjectCard.astro";
import Icon from "./Icon.astro";
import * as projectsData from "../data/projects.md";
import esTranslations from "../i18n/es.json";
import enTranslations from "../i18n/en.json";

interface Props {
  lang?: string;
}

const { lang = "es" } = Astro.props as Props;
const t = (lang === "en" ? enTranslations : esTranslations) as typeof esTranslations;

const { techStack, projects } = projectsData.frontmatter as {
  techStack: { frontend: any[]; backend: any[] };
  projects: any[];
};

// Lógica de grilla automática (Zig-Zag)
// 0: featured (8), 1: card (4), 2: card (4), 3: featured (8)
const getLayoutType = (index: number) => {
  const patternIndex = index % 4;
  if (patternIndex === 0 || patternIndex === 3) return index % 4 === 3 ? 'horizontal' : 'featured';
  return 'card';
};
---

<Section class="bg-surface-container-low py-24" id="projects">
  <div class="max-w-7xl mx-auto px-8">
    <!-- Header and Search -->
    <div class="reveal flex flex-col md:flex-row justify-between items-end gap-6 mb-16">
      <div>
        <h2 class="font-headline text-3xl md:text-4xl font-extrabold text-on-surface mb-2">{t.projects.title}</h2>
        <p class="text-on-surface-variant">{t.projects.description}</p>
      </div>
      <div class="w-full md:w-96 relative">
        <Icon name="link" class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-outline" />
        <input 
          id="project-search"
          class="w-full bg-surface-container-lowest border-none rounded-xl py-4 pl-12 pr-4 text-on-surface placeholder:text-outline focus:ring-2 focus:ring-primary transition-all shadow-inner" 
          placeholder={t.projects.searchPlaceholder} 
          type="text"
        />
      </div>
    </div>

    <!-- Tech Stack Carousels -->
    <div class="reveal space-y-8 mb-20">
      {Object.entries(techStack).map(([key, items]) => (
        <div class="relative group">
          <div class="flex items-center gap-4 mb-4 text-xs font-bold uppercase tracking-widest text-primary/70 px-2">
            <span>{t.projects.categories[key as keyof typeof t.projects.categories]}</span>
            <div class="h-px flex-1 bg-outline-variant/15"></div>
          </div>
          <div class="flex gap-4 overflow-x-auto hide-scrollbar pb-4 scroll-smooth">
            {items.map((item: any) => (
              <TechItem name={item.name} icon={item.icon} />
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Project Grid Automatizada -->
    <div id="project-grid" class="grid grid-cols-1 md:grid-cols-12 gap-8">
      {projects.map((project, i) => (
        <ProjectCard 
          project={project} 
          t={t} 
          layoutType={getLayoutType(i)} 
        />
      ))}
    </div>

    <!-- No Results Message -->
    <div id="no-results" class="hidden py-20 text-center reveal">
      <Icon name="code" class="w-16 h-16 text-outline mb-4 mx-auto" />
      <p class="text-xl font-bold text-on-surface">{t.projects.noResults}</p>
    </div>

    <!-- Pagination Buttons -->
    <div id="project-pagination" class="flex justify-center items-center gap-6 mt-16 reveal">
      <button id="show-less-projects" class=" w-12 h-12 flex items-center justify-center rounded-full bg-surface-container-high border border-outline-variant/30 text-on-surface-variant hover:text-primary transition-all hover:scale-110 active:scale-90" aria-label="Mostrar menos">
        <span class="material-symbols-outlined">remove</span>
      </button>
      <button id="show-more-projects" class="w-12 h-12 flex items-center justify-center rounded-full bg-on-surface text-surface hover:bg-primary transition-all hover:scale-110 active:scale-90 shadow-lg shadow-primary/20" aria-label="Mostrar más">
        <span class="material-symbols-outlined font-bold">add</span>
      </button>
    </div>
  </div>
</Section>

<script>
  function initSearch() {
    const searchInput = document.getElementById('project-search') as HTMLInputElement;
    const projectGrid = document.getElementById('project-grid');
    const noResults = document.getElementById('no-results');
    const paginationContainer = document.getElementById('project-pagination');
    const showMoreBtn = document.getElementById('show-more-projects');
    const showLessBtn = document.getElementById('show-less-projects');
    const cards = document.querySelectorAll('.project-card');
    const techButtons = document.querySelectorAll('.tech-filter-btn');
    
    let activeTechs = new Set<string>();
    let visibleLimit = 4;

    if (!searchInput || !cards.length) return;

    function applyFilters() {
      const term = searchInput.value.toLowerCase().trim();
      let matchingCount = 0;
      let actuallyVisible = 0;

      cards.forEach((card) => {
        const name = (card as HTMLElement).dataset.name || '';
        const tags = ((card as HTMLElement).dataset.tags || '').split(',');
        
        // 1. Filtrado por texto y tags (Base)
        const matchesText = name.includes(term) || tags.some(t => t.includes(term));
        const matchesTechs = activeTechs.size === 0 || Array.from(activeTechs).every(tech => tags.includes(tech));

        const isMatch = matchesText && matchesTechs;

        if (isMatch) {
          matchingCount++;
          // 2. Aplicar límite de paginación sobre los resultados que coinciden
          if (matchingCount <= visibleLimit) {
            const el = card as HTMLElement;
            el.classList.remove('hidden');
            
            // Recálculo dinámico del layout zig-zag
            const patternIndex = actuallyVisible % 4;
            let newLayout = 'card';
            if (patternIndex === 0 || patternIndex === 3) {
              newLayout = patternIndex === 3 ? 'horizontal' : 'featured';
            }
            el.dataset.layout = newLayout;
            
            actuallyVisible++;
          } else {
            (card as HTMLElement).classList.add('hidden');
          }
        } else {
          (card as HTMLElement).classList.add('hidden');
        }
      });

      // Toggle no results message
      if (matchingCount === 0) {
        projectGrid?.classList.add('hidden');
        noResults?.classList.remove('hidden');
        paginationContainer?.classList.add('hidden');
      } else {
        projectGrid?.classList.remove('hidden');
        noResults?.classList.add('hidden');
        paginationContainer?.classList.remove('hidden');
      }

      // Visibility of pagination buttons
      if (matchingCount > visibleLimit) {
        showMoreBtn?.classList.remove('hidden');
      } else {
        showMoreBtn?.classList.add('hidden');
      }

      if (visibleLimit > 4) {
        showLessBtn?.classList.remove('hidden');
      } else {
        showLessBtn?.classList.add('hidden');
      }
    }

    // Event Listeners para el buscador
    searchInput.addEventListener('input', () => {
      visibleLimit = 4; // Reset pagination on search
      applyFilters();
    });

    // Event Listeners para los botones de tecnología
    techButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const tech = (btn as HTMLElement).dataset.tech || '';
        if (activeTechs.has(tech)) {
          activeTechs.delete(tech);
          btn.classList.remove('active');
        } else {
          activeTechs.add(tech);
          btn.classList.add('active');
        }
        visibleLimit = 4; // Reset pagination on tag change
        applyFilters();
      });
    });

    // Event Listeners para Paginación
    showMoreBtn?.addEventListener('click', () => {
      visibleLimit += 2;
      applyFilters();
    });

    showLessBtn?.addEventListener('click', () => {
      visibleLimit = 4;
      applyFilters();
    });

    // Carga inicial
    applyFilters();
  }

  // Support for Astro Page Loads / Transitions
  document.addEventListener('DOMContentLoaded', initSearch);
  document.addEventListener('astro:page-load', initSearch);
</script>

<style>
  .hide-scrollbar::-webkit-scrollbar { display: none; }
  .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>
