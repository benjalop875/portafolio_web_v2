---
import Section from "./Section.astro";
import esTranslations from "../i18n/es.json";
import enTranslations from "../i18n/en.json";

interface Props {
  lang?: string;
}

const { lang = "es" } = Astro.props as Props;
const t = (lang === "en" ? enTranslations : esTranslations) as typeof esTranslations;
---

<Section class="bg-surface-container-low py-24" id="contact">
  <div class="max-w-3xl mx-auto px-8">
    <div id="contact-header" class="reveal text-center mb-16">
      <h2 class="font-headline text-3xl md:text-4xl font-extrabold text-on-surface mb-4">{t.contact.title}</h2>
      <p class="text-on-surface-variant">{t.contact.description}</p>
    </div>

    <form id="contact-form" class="reveal space-y-6" data-error-msg={t.contact.error.message}>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="group relative">
          <label class="block text-xs font-bold uppercase tracking-widest text-outline mb-2 ml-1 group-focus-within:text-primary transition-colors">
            {t.contact.fields.name}
          </label>
          <div class="relative">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline group-focus-within:text-primary transition-colors">person</span>
            <input 
              required
              name="name"
              type="text" 
              placeholder={t.contact.placeholders.name}
              class="w-full bg-surface-container border-2 border-transparent rounded-2xl py-4 pl-12 pr-6 text-on-surface focus:border-primary focus:bg-surface-bright outline-none transition-all shadow-inner"
            />
          </div>
        </div>
        
        <div class="group relative">
          <label class="block text-xs font-bold uppercase tracking-widest text-outline mb-2 ml-1 group-focus-within:text-primary transition-colors">
            {t.contact.fields.email}
          </label>
          <div class="relative">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline group-focus-within:text-primary transition-colors">mail</span>
            <input 
              required
              name="email"
              type="email" 
              placeholder={t.contact.placeholders.email}
              class="w-full bg-surface-container border-2 border-transparent rounded-2xl py-4 pl-12 pr-6 text-on-surface focus:border-primary focus:bg-surface-bright outline-none transition-all shadow-inner"
            />
          </div>
        </div>
      </div>

      <div class="group relative">
        <label class="block text-xs font-bold uppercase tracking-widest text-outline mb-2 ml-1 group-focus-within:text-primary transition-colors">
          {t.contact.fields.message}
        </label>
        <div class="relative">
          <span class="material-symbols-outlined absolute left-4 top-5 text-outline group-focus-within:text-primary transition-colors">chat_bubble</span>
          <textarea 
            required
            name="message"
            rows="5" 
            placeholder={t.contact.placeholders.message}
            class="w-full bg-surface-container border-2 border-transparent rounded-2xl py-4 pl-12 pr-6 text-on-surface focus:border-primary focus:bg-surface-bright outline-none transition-all shadow-inner resize-none"
          ></textarea>
        </div>
      </div>

      <button 
        type="submit"
        id="submit-btn"
        class="w-full bg-linear-to-br from-primary to-primary-container text-white py-5 rounded-2xl font-bold hover:scale-[0.99] hover:shadow-xl hover:shadow-primary/20 transition-all flex items-center justify-center gap-3 group relative overflow-hidden"
      >
        <div class="flex items-center gap-2 group-active:scale-90 transition-transform">
          <span id="btn-text" data-sending={t.contact.button.sending}>{t.contact.button.default}</span>
          <span class="material-symbols-outlined text-xl group-hover:translate-x-1 transition-transform">send</span>
        </div>
      </button>
    </form>

    <div id="success-message" class="hidden text-center py-12 reveal">
      <div class="w-24 h-24 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-8 shadow-2xl shadow-primary/20 scale-0 transition-transform duration-500" id="success-icon">
        <span class="material-symbols-outlined text-5xl text-primary font-bold">check_circle</span>
      </div>
      <h3 class="text-3xl font-extrabold text-on-surface mb-4">{t.contact.success.title}</h3>
      <p class="text-on-surface-variant max-w-md mx-auto leading-relaxed">
        {t.contact.success.message}
      </p>
      <button 
        id="reset-form"
        class="mt-10 text-primary font-bold hover:underline underline-offset-4 flex items-center gap-2 mx-auto"
      >
        <span class="material-symbols-outlined text-sm">arrow_back</span>
        Volver a enviar
      </button>
    </div>
  </div>
</Section>

<script>
  function initContact() {
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const header = document.getElementById('contact-header');
    const successMsg = document.getElementById('success-message');
    const successIcon = document.getElementById('success-icon');
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const btnText = document.getElementById('btn-text');
    const resetBtn = document.getElementById('reset-form');

    if (!form || !submitBtn || !successMsg) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      
      // Visual feedback: Sending...
      submitBtn.disabled = true;
      const originalText = btnText!.textContent;
      const sendingText = btnText?.getAttribute('data-sending') || '...';
      btnText!.textContent = sendingText;
      
      try {
        const response = await fetch('https://formspree.io/f/benjalop875@gmail.com', {
          method: 'POST',
          body: formData,
          headers: {
            'Accept': 'application/json'
          }
        });

        if (response.ok) {
          // Success animation
          form.classList.add('hidden');
          header?.classList.add('hidden');
          successMsg.classList.remove('hidden');
          
          setTimeout(() => {
            successIcon?.classList.remove('scale-0');
            successIcon?.classList.add('scale-100');
          }, 100);
          form.reset();
        } else {
          const errorData = await response.json();
          alert(form.getAttribute('data-error-msg') || 'Error al enviar el mensaje.');
          console.error('Formspree Error:', errorData);
        }
      } catch (error) {
        alert(form.getAttribute('data-error-msg') || 'Error de conexión.');
        console.error('Submission Error:', error);
      } finally {
        submitBtn.disabled = false;
        btnText!.textContent = originalText;
      }
    });

    resetBtn?.addEventListener('click', () => {
      successMsg.classList.add('hidden');
      successIcon?.classList.remove('scale-100');
      successIcon?.classList.add('scale-0');
      form.classList.remove('hidden');
      header?.classList.remove('hidden');
    });
  }

  document.addEventListener('DOMContentLoaded', initContact);
  document.addEventListener('astro:page-load', initContact);
</script>
