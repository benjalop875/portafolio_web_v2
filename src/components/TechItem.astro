---
import Icon from './Icon.astro';

interface Props {
  name: string;
  icon: string;
}

const { name, icon } = Astro.props;
---
<button 
  class="tech-filter-btn flex-none bg-surface-container-high px-6 py-4 rounded-2xl border border-outline-variant/15 hover:border-primary/50 transition-all flex items-center gap-3 cursor-pointer group"
  data-tech={name.toLowerCase()}
  aria-label={`Filtrar por ${name}`}
>
  <Icon name={icon} class="w-6 h-6 text-primary group-hover:scale-110 transition-transform" />
  <span class="font-label font-bold text-on-surface">{name}</span>
</button>
