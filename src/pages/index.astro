<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="refresh" content="2;url=/es/" />
    <title>benjalop.dev | Bienvido</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;700&family=Manrope:wght@800&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #8083FF;
            --background: #0f1014;
            --on-surface: #e4e1e6;
        }
        
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background-color: var(--background);
            color: var(--on-surface);
            font-family: 'Outfit', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            overflow: hidden;
            position: relative;
        }

        /* Hero Mesh Background (Matches Hero.astro) */
        .mesh {
            position: absolute;
            inset: 0;
            background-image: 
                radial-gradient(at 0% 0%, rgba(128, 131, 255, 0.15) 0px, transparent 50%),
                radial-gradient(at 100% 0%, rgba(255, 183, 131, 0.1) 0px, transparent 50%),
                radial-gradient(at 50% 100%, rgba(128, 131, 255, 0.05) 0px, transparent 50%);
            z-index: 0;
        }

        .content {
            position: relative;
            z-index: 10;
            text-align: center;
            animation: fadeIn 1s ease-out;
        }

        .logo {
            font-family: 'Manrope', sans-serif;
            font-size: 2.5rem;
            font-weight: 800;
            letter-spacing: -0.05em;
            margin-bottom: 1.5rem;
            background: linear-gradient(135deg, #fff 0%, var(--primary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .loader-container {
            width: 200px;
            height: 4px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 10px;
            margin: 0 auto;
            overflow: hidden;
            position: relative;
        }

        .loader-bar {
            position: absolute;
            height: 100%;
            width: 40%;
            background: var(--primary);
            border-radius: 10px;
            box-shadow: 0 0 20px rgba(128, 131, 255, 0.5);
            animation: loading 2s infinite ease-in-out;
        }

        .text {
            margin-top: 1.5rem;
            font-size: 0.9rem;
            font-weight: 300;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            opacity: 0.6;
        }

        @keyframes loading {
            0% { left: -40%; }
            50% { left: 100%; }
            100% { left: -40%; }
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        a {
            color: var(--primary);
            text-decoration: none;
            font-weight: 700;
            display: inline-block;
            margin-top: 2rem;
            font-size: 0.8rem;
            opacity: 0;
            animation: fadeIn 0.5s 3s forwards;
        }
    </style>
</head>
<body>
    <div class="mesh"></div>
    <div class="content">
        <h1 class="logo">benjalop.dev</h1>
        <div class="loader-container">
            <div class="loader-bar"></div>
        </div>
        <p class="text">Preparando experiencia</p>
        <a href="/es/">¿No fuiste redirigido? Click aquí</a>
    </div>

    <script>
        // Redirección rápida por JS
        setTimeout(() => {
            window.location.replace('/es/');
        }, 1500);
    </script>
</body>
</html>
